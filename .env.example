APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=masjids management system
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Security: keep these as `true` in production. Override only for local plain-HTTP dev.
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# Security: comma-separated list of origins allowed to call the API via CORS.
# Use the EXACT origin including scheme. Wildcard (*) means anyone — only use
# in dev and only if your endpoints don't accept credentials.
CORS_ALLOWED_ORIGINS=https://your-admin.example.com,https://your-site.example.com

# Security: Sanctum personal access token expiration in minutes (8 hours default).
SANCTUM_EXPIRATION=480

# Security: Pusher webhook signature secret. Populate from Pusher dashboard.
PUSHER_WEBHOOK_SECRET=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ONESIGNAL_REST_API_URL=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
# Account-scoped key (called "Organization REST API Key" on newer accounts,
# "User Auth Key" on older ones). Required for the splash announcement IAM
# sync — the app-scoped REST key above returns "Please include … User Auth
# Key" when used against /apps/{id}/in_app_messages. Find at:
# https://dashboard.onesignal.com → name top right → Account → Keys & IDs.
ONESIGNAL_USER_AUTH_KEY=

VITE_APP_NAME="${APP_NAME}"
