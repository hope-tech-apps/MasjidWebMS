APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=masjids management system
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Security: keep these as `true` in production. Override only for local plain-HTTP dev.
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# Security: comma-separated list of origins allowed to call the API via CORS.
# Use the EXACT origin including scheme. Wildcard (*) means anyone — only use
# in dev and only if your endpoints don't accept credentials.
CORS_ALLOWED_ORIGINS=https://your-admin.example.com,https://your-site.example.com

# Security: Sanctum personal access token expiration in minutes (8 hours default).
SANCTUM_EXPIRATION=480

# Security: Pusher webhook signature secret. Populate from Pusher dashboard.
PUSHER_WEBHOOK_SECRET=

# Stripe (CRM donations — Connect Standard accounts + direct charges).
# Leave the three secrets EMPTY here; populate real test-mode values in .env.
# STRIPE_KEY/STRIPE_SECRET are the test-mode API keys (pk_test_/sk_test_);
# STRIPE_WEBHOOK_SECRET (whsec_...) is the signing secret that gates the
# unauthenticated /api/stripe/webhook route. Optional tunables below have
# working defaults in config/services.php and normally stay unset.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# STRIPE_FEE_PERCENTAGE=0.029      # Stripe's fee %, used for donor-covers-fees gross-up
# STRIPE_FEE_FIXED=30              # Stripe's fixed fee in minor units (cents)
# STRIPE_PLATFORM_FEE_PERCENTAGE=0 # platform application_fee share of the donation
# STRIPE_CURRENCY=usd              # default settlement currency

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ONESIGNAL_REST_API_URL=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
# Account-scoped key (called "Organization REST API Key" on newer accounts,
# "User Auth Key" on older ones). Required for the splash announcement IAM
# sync AND for per-masjid OneSignal app auto-provisioning (creating apps).
# The app-scoped REST key above returns "Please include … User Auth Key" when
# used against /apps/{id}/... Find at:
# https://dashboard.onesignal.com → name top right → Account → Keys & IDs.
ONESIGNAL_USER_AUTH_KEY=

# --- Per-masjid OneSignal app auto-provisioning (org-level M2M creds) ---
# Used ONLY by App\Services\OneSignalProvisioningService to mint a per-masjid
# OneSignal app so onboarding needs no manual dashboard step. All optional:
# when unset, provisioning returns a clear error and the shared app keeps
# working. See config/services.php ('onesignal' block).
#
# OneSignal Apps API endpoint (leave default unless OneSignal changes it).
ONESIGNAL_APPS_API_URL=https://api.onesignal.com/apps
# Team APNs auth key used to seed iOS push on newly created apps. ONESIGNAL_APNS_P8
# is the RAW contents of the AuthKey_XXXX.p8 file (BEGIN/END PRIVATE KEY block).
ONESIGNAL_APNS_P8=
ONESIGNAL_APNS_KEY_ID=
ONESIGNAL_APNS_TEAM_ID=
# APNs environment for created apps: production | sandbox.
ONESIGNAL_APNS_ENV=production
# FCM v1 service-account JSON (raw JSON) to seed Android push on new apps.
ONESIGNAL_FCM_V1_SERVICE_ACCOUNT_JSON=

# --- App-provisioning control plane (GitHub repository_dispatch) ---
# The Super-Admin "Generate apps" action fires a GitHub repository_dispatch to a
# mobile repo whose workflow (self-hosted runner) scaffolds + builds + uploads a
# masjid's app. See config/services.php ('github' block).
#
# Org / fine-grained PAT authorizing POST /repos/{owner/repo}/dispatches on the
# two mobile repos (needs `contents:read` + Dispatch, or classic `repo`). Wire it
# as an ORG SECRET. When unset, a dispatch fails-soft with a clear error (the job
# is marked failed) instead of crashing. NEVER hardcode or echo this.
GITHUB_DISPATCH_TOKEN=
# The full "owner/repo" each platform dispatches to (defaults shown).
GITHUB_IOS_REPO=hope-tech-apps/burlington-masjid-iOS
GITHUB_ANDROID_REPO=hope-tech-apps/burlington-masjid-Android
# Platform-default Apple Developer Team ID for signing managed-tier iOS builds.
# Overridden per-masjid by masjid_app_publishing.development_team (BYO) when set.
APPLE_DEVELOPMENT_TEAM=
# Default reverse-DNS prefix for a derived iOS bundle id when no explicit
# bundle_id override is supplied on the "Generate apps" request.
IOS_BUNDLE_PREFIX=com.hopetechapps

VITE_APP_NAME="${APP_NAME}"
